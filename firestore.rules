rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Products: public read, admin-only write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: anyone can create (for guest checkout); users can read own, admins can read/update all
    match /orders/{orderId} {
      allow create: if true;
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Users: users can read/write their own doc; admins can read/write any user doc
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());

      match /favorites/{favoriteId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Payment methods: public read (checkout screen), admin-only write
    match /payment_methods/{methodId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // App settings: public read, admin-only write
    match /app_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
